# 复制为本目录下的 build.local.env（已在 .gitignore，勿提交）。
# scripts/release_dmg.sh 和 scripts/package_dmg.sh 当前不会自动 source；如需生效，请先手动执行: source scripts/build.local.env
#
# 用钥匙串里「某张证书」对应的一小段唯一字段筛选签名（见 security find-identity -v -p codesigning）
# 例如邮箱、Team ID、或证书 Common Name 里的连续字符：
# export SIGNING_IDENTITY_HINT='2082519537@qq.com'
#
# 或写死整张证书名称（优先级高于 HINT）：
# export SIGNING_IDENTITY='Developer ID Application: Your Name (XXXXXXXXXX)'
#
# 注意：codesign 只使用本机钥匙串里的证书，不会读取 Apple ID 登录密码。
# 公证（notarytool）须单独配置钥匙串 profile + App 专用密码，不要把密码写进仓库。

# Voice Agent OpenAI-compatible runtime config:
# export AHAKEY_OPENAI_API_KEY='<set-locally>'
# export AHAKEY_OPENAI_BASE_URL='https://api.openai-next.com'
# export AHAKEY_OPENAI_MODEL='deepseek/deepseek-v4-flash'
#
# 也可以把 API key 写入 macOS Keychain，运行时会在环境变量缺失时读取：
# security add-generic-password -a openai-compatible-api-key -s com.ahakey.voiceagent -w "$AHAKEY_OPENAI_API_KEY" -U
